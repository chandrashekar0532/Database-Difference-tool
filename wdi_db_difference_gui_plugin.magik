# ==============================================================================
# from ---Checkpoint list helper
# ==============================================================================
_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.chk_list()
	##
	## Build and return a rope of checkpoint display strings for the
	## FROM / TO CHECKPOINT dropdowns.
	## Format: "checkpoint_name (timestamp)"
	##

	_local chk_rp << rope.new_with("---Select---", "***disk version***")
	_local gpm << gis_program_manager
	_local db_view << gpm.databases[.current_dataset]

	_if db_view _isnt _unset
	_then
		_for chk _over db_view.checkpoints.fast_elements()
		_loop
			_local cp_name << chk.checkpoint_name
			_local cp_time << chk.time_created.write_string
			_local display_str << cp_name + " (" + cp_time + ")"

			chk_rp.add(display_str)
		_endloop
	_endif

	>> chk_rp
_endmethod
$

# ==============================================================================
# Find Differences
# ==============================================================================
_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.find_difference()
	##
	## Main entry point for the "Find Difference" button.
	## Validates user selections and delegates to either
	## get_alternative_differences() or get_checkpoint_differences().
	##
	
	_local new_view, old_view, tables, ht, ct, lc ,l_app,chk_view

    	_if smallworld_product.release_version =  3
	_then 
		
		l_app <<  gis_program_manager.applications[:gis]

	_elif smallworld_product.release_version =  4 _orif smallworld_product.release_version =  5
	_then 
	
	  l_app << smallworld_product.application(:cam_db_swaf_professional)
	_endif 
	 l_table_list <<_self.get_selected_tables()
	 
	# Require at least one table to be selected
	_if l_table_list.empty?
	_then
		l_app.show_message( "Please select atleast one Table to find data differences  ")
		 _return
	_endif

	 _if .items[:rb_alt].value _is _true
	 _then
		 # ---- Alternative mode ------------------------------------------------
		 from_alt << .items[:from_alternative].value
		 to_alt << .items[:to_alternative].value
		 _if from_alt = "" _orif
		     to_alt = " "
		 _then
			 l_app.show_message( "Please select Alternative to fetch the data differences ")
			 _return 
		 _endif
		 .items[:st].value << " Fetching data diffrernces between selected Alternatives "
		 _self.get_alternative_differences()
		 
	 _elif .items[:rb_chk].value _is _true
	 _then
		 # ---- Checkpoint mode -------------------------------------------------
		 from_chk << .items[:from_checkpoint].value.write_string
		 to_chk << .items[:to_checkpoint].value.write_string
		 _if from_chk = "---Select---" _orif
		     to_chk = "---Select--"
		 _then
			 l_app.show_message( "Please select Checkpoint to fetch the data differences ")
			 _return 
		 _endif
		 .items[:st].value << " Fetching data diffrernces between selected checkpoint "
		 _self.get_checkpoint_differences()
	 _else
		 # ---- No mode selected -----------------------------------------------
		 l_app.show_message( "Please select Alternative\Checkpoint mode to fetch the data differences. ")
		 _return 
	 _endif	
_endmethod
$
_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.get_checkpoint_differences()
	## 
	##Compare differences between two checkpoints
	
	_local from_alt,from_chk,chk_view,to_chk,old_view,new_view,from_chk_view,to_chk_view,ht, ct, lc
	
	# Extract values from GUI
        from_alt << .items[:from_alternative].value
	to_alt << .items[:to_alternative].value
	from_chk << .items[:from_checkpoint].value.split_by("(").first.trim_spaces()
	to_chk << .items[:to_checkpoint].value.split_by("(").first.trim_spaces()
	
	# Switch to the selected alternative

	.db_view.go_to_alternative(from_alt)

	# Build views for FROM and TO checkpoints
	_if from_chk = "***disk version***" 
	_then
		chk_view << .db_view.go_to_checkpoint(to_chk,:readonly)
		
		old_view<< .db_view.replicate()
		
		.db_view.rollforward()
		
		new_view << .db_view
		
	_elif to_chk = "***disk version***" 
	_then
		chk_view << .db_view.go_to_checkpoint(from_chk,:readonly)
		
		old_view<< .db_view.replicate()
		
		.db_view.rollforward()
		
		new_view << .db_view
	_else
		.db_view.go_to_alternative(from_alt)
		from_chk_view << .db_view.go_to_checkpoint(from_chk,:readonly)
		
		old_view<< .db_view.replicate()
		
		.db_view.go_to_alternative(to_alt)
		to_chk_view << .db_view.go_to_checkpoint(to_chk,:readonly)
		
		new_view << .db_view	
	_endif
	
	# Get selected tables
	lc << _self.get_selected_tables()
	
        # Run difference engine
	(ht, ct, lc) << .db_diff_eng.difference_db(new_view, old_view)
	
	# Build and display results
	_self.build_results_display(ht, old_view, new_view)
	
_endmethod
$
_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.get_alternative_differences()
	## 
	## 
        _local from_alt, to_alt, old_view, new_view,ht, ct, lc
	
        #alternatives mode
	from_alt << .items[:from_alternative].value     
	to_alt << .items[:to_alternative].value
	
	.db_view.go_to_alternative(from_alt)
	
	old_view<< .db_view.replicate()

	.db_view.go_to_alternative(to_alt)
	
	.db_view.rollforward()
	
	new_view << .db_view

	# Get selected tables
	lc << _self.get_selected_tables()

	# Run difference engine
	(ht, ct, lc) << .db_diff_eng.difference_db(new_view, old_view)

	# Build and display results
	_self.build_results_display(ht, old_view, new_view)
	
_endmethod
$
# ==============================================================================
# Field comparison helper
# ==============================================================================
_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.compare_record(old,new,rec,field)
	##
	## Compare the value of a single field between the old and new views for
	## the record identified by rec
	##
	_local coll_name, old_rec, new_rec, old_val, new_val

	# Safe collection name
	_if rec.source_collection.responds_to?(:name)
	_then
		coll_name << rec.source_collection.name
	_else
		coll_name << rec.source_collection.external_name
	_endif

	# Choose identifier field
	_local key_field
	_if rec.responds_to?(:name)
	_then
		
		key_field << :name
		key_val << rec.name
	_elif rec.responds_to?(:id)
	_then
		key_field << :id
		key_val << rec.id
	_else
		write("Warning: record has no :name or :id, skipping")
		_return _false
	_endif

	# Select records safely
	old_rec << old.collections[coll_name].select(predicate.eq(key_field, key_val)).an_element()
	new_rec << new.collections[coll_name].select(predicate.eq(key_field, key_val)).an_element()

	_if old_rec _is _unset _orif new_rec _is _unset
	_then
		write("Warning: could not locate matching records in ", coll_name)
		_return _false
	_endif

	# Compare field values
	_try
		old_val << old_rec.perform(field)
		new_val << new_rec.perform(field)

		_if old_val <> new_val
		_then
			_return _true, old_val, new_val
		_endif
	_when error
		write("Error comparing field ", field, " in ", coll_name)
		_return _false
	_endtry

	_return _false
_endmethod
$
# ==============================================================================
# Version dialog helpers  (FROM and TO)
# ==============================================================================
_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.open_version_dialog_from()
	##
	## Opens the Version Management dialog to select the FROM alternative.
	## .last_dialog_opened is set to :from so on_deactivation knows
	## which text box to update.
	##
		
		write("+++ 2222222222222 +++")
		
	_if .current_dataset _is _unset
	_then
		_self.user_error("Please select a dataset first")
		_return
	_endif

	.last_dialog_opened << :from
	
        _if smallworld_product.release_version = 3
        _then
	 l_app <<  gis_program_manager.applications[:gis]
	 l_app.activate_version_control()
	 
	 _elif smallworld_product.release_version = 4 _orif smallworld_product.release_version =  5
         _then
	       write("+++ 11111111 +++")
	       
	      _local vm_plugin << smallworld_product.applications.an_element().plugin(:versions)  
	      _if vm_plugin _isnt _unset
	      _then
		      vm_plugin.activate_as_dialog("", "")
	       _else
		_self.user_error("Version Management plugin not available")
	       _endif
	_else
		write("version management error")
        _endif 

_endmethod
$

_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.open_version_dialog_to()
	##
	## Opens the Version Management dialog to select the TO alternative.
	##
		
	_if .current_dataset _is _unset
	_then
		_self.user_error("Please select a dataset first")
		_return
	_endif

	.last_dialog_opened << :to

	_if smallworld_product.release_version = 3
        _then
		l_app <<  gis_program_manager.applications[:gis]
		l_app.activate_version_control()
		
	_elif smallworld_product.release_version = 4 _orif smallworld_product.release_version =  5
	_then
		
		_local vm_plugin << smallworld_product.applications.an_element().plugin(:versions)  
		_if vm_plugin _isnt _unset
		_then
			vm_plugin.activate_as_dialog("", "")
		_else
			_self.user_error("Version Management plugin not available")
		_endif
	_else
		write("version management error")
        _endif 

_endmethod
$

_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.export_results()
	## 
	##
 
	# Save the report in the selected location
	args << rope.new_with(:do_creation_check?,_true)
 
	_if _self.report_dir _isnt _unset
	_then
		args.add_all_last({:directory, _self.report_dir})
	_endif
	report_file_selector <<
		file_selection.new(_self,
				   "Save File",  
				   :|open_file()|, _unset,
				   _scatter args)
 
	report_file_selector.filter       << "*.xls"
	report_file_selector.directories? << _false
 
	report_file_selector.activate()
_endmethod
$


_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.open_file(fname)
	## get the selected row key and use it to obtain the network
	## element from the .list
	##
        _local output_stream, selected_element, l_app

	l_app << smallworld_product.applications.an_element()
	
	selected_element << .items[:tree_item].selection.an_element()
	_protect
		_if selected_element _isnt _unset
		_then
			# Create CSV file
			output_stream << external_text_output_stream.new(fname)

			
			# Write header
			output_stream.write("SNO,Table Name,Table Key Field,Table Key Value, Operation Type,Updated Field name,Before Value,Afetr Value", newline_char)
			
                        #	output_stream.write("SNO","|","Table Name","|","Table Key Field","|","Table Key Value","|","Operation Type","|","Updated Field name","|","Before Value","|","Afetr Value", newline_char)
			# Write each difference record (including children)
			_for a_diff _over .list.fast_elements()
			_loop
				val << a_diff.value
				l_kvalue << val[:table_key_value].write_string
				l_kvalue  << l_kvalue.replace_all_instances_of(","," ")
				output_stream.write(val[:Sno], ",",
						    val[:Table_name],",",
						    val[:table_key_field], ",",
						    #val[:table_key_value], ",",
						    l_kvalue, ",",
						    val[:Operation_type], ",",
						    val[:updated_fields], ",",
						    val[:before_value].replace_all_instances_of(","," "), ",",
						    val[:after_value].replace_all_instances_of(","," "),newline_char)
				
				
				
				# Export children if present
				_if a_diff.children.size > 0
				_then
					
					_for child _over a_diff.children.fast_elements()
					_loop
						cval << child.value
						l_ckvalue << cval[:table_key_value].write_string
						l_ckvalue << l_ckvalue.replace_all_instances_of(","," ")
						output_stream.write(cval[:Sno], ",",
								    cval[:Table_name],"," ,
								    cval[:table_key_field], ",",
								    #cval[:table_key_value], ",",
								    l_ckvalue, ",",
								    cval[:Operation_type], ",",
								    cval[:updated_fields], ",",
								    cval[:before_value].replace_all_instances_of(","," "), ",",
								    cval[:after_value].replace_all_instances_of(","," "),newline_char)
					_endloop
				_endif
			_endloop
		_else
			l_app.show_message( "Please select atleast one row in results table ")
			_return	
		_endif
		
	_protection
		output_stream.close()
	_endprotect	
_endmethod
$

_method simple_charindex_mixin.replace_all_instances_of(p_old_str, p_new_str)
	_local       m_new_str << ""
	_local             m_i << 1
	_local        m_match? << _false
	_local          m_part << ""
 
	_for c _over _self.fast_elements()
	_loop
		_if m_part = p_old_str
		_then
			m_part << ""
			m_new_str +<< p_new_str
			m_i << 1
		_endif
		_if c <>  p_old_str[m_i] 
		_then
			m_part << ""
			m_new_str +<< c
			m_i << 1
		_else
			m_part +<< c
			m_i +<< 1
		_endif
	_endloop
 
	#just in case the match was the last char
	_if m_part = p_old_str
	_then
		m_new_str +<< p_new_str
	_endif
 
	_return m_new_str
_endmethod
$

_pragma(classify_level=restricted, topic={tree_item}, usage={internal})
_method tree_agent.handle_toggle(p_tree, _optional p_row_index, p_event, p_value, p_text_style, p_text, p_dx, p_dy)
	## Parameters    : P_TREE: The display tree on which the user
	##                    changed a radio_toggle.
	##                 P_ROW_INDEX: Index in the list of visible
	##                    display trees.
	##                 P_EVENT: Event that has been raised
	##                 P_VALUE: _unset, or the :index in the
	##                    display_trees value if the text comes from a :value mark
	##                 P_TEXT_STYLE: Which is always :resolved_image
	##                 P_IMAGE: The image as it has been resolved
	##                 P_DX, P_DY: Relative position in P_IMAGE
	##                    (compared to P_TEXT top left being (0,0)
	## Returns       : _false, denoting that we do not want the
	##                 agent to redraw (which is done manually,
	##                 called from this method).
	## Function      : Use the style_holder to resolve the new
	##                 value (toggle) for the index P_VALUE. That
	##                 is stored then in P_TREE.value(P_VALUE) << .
	##                 If the value changed, value_changed_notifier will be called.
	
	_local l_old_value << p_tree.value(p_value)
	_local l_new_value << _self.style_holder.resolve_toggle(l_old_value, :toggle, p_value)
	_if (l_old_value _isnt l_new_value)
	_then
		p_tree.value(p_value) << l_new_value
		_self.notify(:value_click_notifier, p_tree, p_value, l_new_value, l_old_value, _unset)
		# ToDo: Improve this: we only need to redraw this row
		_self.damaged(_unset)
	_endif
	# we do not want to redraw
	>> _false
_endmethod
$
# ==============================================================================
# version_management_framework callback
# ==============================================================================
_method version_management_framework.on_deactivation()
	##
	## Called automatically when the Version Management dialog closes.
	##
	## HOW WE AVOID GLOBALS:
	##   - Instead of the old  _global db_dff_plugin  we read the class
	##     shared-variable  my_menu_rc.active_instance  which was set in
	##     activate_in().
	##   - Instead of the old  _global select_db  we read the slot
	##     .current_dataset  directly from that instance.
	##   Both globals are now completely gone.                           
	##
	write("+++version_management_framework.on_deactivation() called +++")
	
	_local gpm, current_alt, db_view, chk_rp, cp_name, cp_time, display_str
	_local l_plugin << wdi_db_difference_gui_plugin.active_instance
	
             write("+++ l_plugin  +++",l_plugin )

	
		gpm     << gis_program_manager
		db_view << gpm.databases[l_plugin.current_dataset]              

		_if db_view _is _unset _orif
		    db_view.current_alternative_details _is _unset
		_then
			_return
		_endif

		current_alt << db_view.current_alternative_details.alternative_name

		chk_rp << rope.new_with("---Select---", "***disk version***")
		_for a_chk _over db_view.checkpoints.fast_elements()
		_loop
			cp_name     << a_chk.checkpoint_name
			cp_time     << a_chk.time_created.write_string
			display_str << cp_name + " (" + cp_time + ")"
			chk_rp.add(display_str)
		_endloop

		_if l_plugin.last_dialog_opened = :from
		_then
			l_plugin.items[:from_alternative].value << current_alt
			l_plugin.items[:from_checkpoint].items  << chk_rp
		_elif l_plugin.last_dialog_opened = :to
		_then
			l_plugin.items[:to_alternative].value << current_alt
			l_plugin.items[:to_checkpoint].items  << chk_rp
		_endif
_endmethod
$
# ==============================================================================
# version_management_framework callback
# ==============================================================================
_method version_form_editor.on_deactivation()
	##
	## Called automatically when the Version Management dialog closes.
	##
	## HOW WE AVOID GLOBALS:
	##   - Instead of the old  _global db_dff_plugin  we read the class
	##     shared-variable  my_menu_rc.active_instance  which was set in
	##     activate_in().
	##   - Instead of the old  _global select_db  we read the slot
	##     .current_dataset  directly from that instance.
	##   Both globals are now completely gone.                           
	##
	write("+++  version_form_editor.on_deactivation() +++")
	
	_local gpm, current_alt, db_view, chk_rp, cp_name, cp_time, display_str
	_local l_plugin << wdi_db_difference_gui_plugin.active_instance
	
	_if l_plugin _is _unset
	_then
		_return
	_endif

	_try
		gpm     << gis_program_manager
		db_view << gpm.databases[l_plugin.current_dataset]

		 
			 
		         (current_alt, alt_rp ) << db_view.alternative_path_name()
			 
	          

		_if db_view _is _unset _orif
		  current_alt _is _unset
		_then
			_return
		_endif

		chk_rp << rope.new_with("---Select---", "***disk version***")
		_for a_chk _over db_view.checkpoints.fast_elements()
		_loop
			cp_name     << a_chk.checkpoint_name
			cp_time     << a_chk.time_created.write_string
			display_str << cp_name + " (" + cp_time + ")"
			chk_rp.add(display_str)
		_endloop


		
		_if l_plugin.last_dialog_opened = :from
		_then
			l_plugin.items[:from_alternative].value << current_alt
			l_plugin.items[:from_checkpoint].set_strings_and_values(chk_rp)
		_elif l_plugin.last_dialog_opened = :to
		_then
			l_plugin.items[:to_alternative].value << current_alt
			l_plugin.items[:to_checkpoint].set_strings_and_values(chk_rp)
		_endif

	_when error
		write("Error in on_deactivation: ", condition.report_contents_string)
	_endtry
_endmethod
$
