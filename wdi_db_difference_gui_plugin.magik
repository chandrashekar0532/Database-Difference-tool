			      :row_headings_alignment, :right,
			      :cell_selection?, _true,
			      :grid_lines?, _true,
			      :mode, :one,
			      :select_notifier, :|selected()|)
	
	# Assign tree_item to itpems for later use
	.items[:tree_item] << l_tree_item
	
	l_tree_item.selection.add_dependent(_self, :anything_selected?)
	
	# --- Report Buttons -----------------------------------------------
	_local l_panel_2 << panel.new(p_frame)
	l_panel_2.resize_x? << _true 
	l_panel_2.resize_y? << _true

	_local panel_rc_2 << rowcol.new(l_panel_2, 1, 2)
	
	.items[:generate_report] << button_item.new_safe(panel_rc_2, "Export Results", _self, :export_results|()|,
							  :row, 1, :col, 1, :enabled?, _false)
	button_item.new_safe(panel_rc_2, "Clear Results", _self, :clear_results|()|, :row, 1, :col, 2)
_endmethod
