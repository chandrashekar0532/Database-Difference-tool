# ************************************************************ 
# Database Difference GUI Plugin 
# ************************************************************ 

#remex(:wdi_db_difference_gui_plugin)

_package user
$
_pragma(classify_level=restricted, topic={db_difference_tool})
##
## wdi_db_difference_gui_plugin
##
## A model-based GUI plugin that builds and manages the Database Difference
## dialog.  It delegates the actual record-level comparison work to an
## instance of wdi_db_difference_engine.
##
# Define the plugin class 
def_slotted_exemplar(:wdi_db_difference_gui_plugin,
	{
	        {:items,               _unset, :writable},  # Property list of all GUI widgets
		{:tree_item,           _unset, :writable},  # Results tree widget reference
		{:table_tree_item,     _unset, :writable},  # Table-selection tree widget
		{:list,                _unset, :writable},  # Rope of result display_tree nodes
		{:table_list,          _unset, :writable},  # Rope of table display_tree nodes
		{:current_dataset,     _unset, :writable},  # Symbol of the selected dataset
		{:db_view,             _unset, :writable},  # Active database view object
		{:last_dialog_opened,  _unset, :writable},  # :from or :to - tracks which button was pressed
		{:db_diff_eng,         _unset, :writable}  # Shared difference engine instance

	},
	:model
)
$

_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.new()
	###
	## Default constructor – creates and initialises a standalone plugin
	## instance (not attached to an engine frame).
	##
	>> _clone.init()
_endmethod
$

_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.init()
	##
	## Initialise all slot values and create the shared difference engine.
	##
	_super.init()
	.items          << property_list.new()
	.table_list     << rope.new()
	.current_dataset  << _unset
	.list           << rope.new()
	.db_diff_eng    << wdi_db_difference_engine.new()
	>> _self 
_endmethod
$

_pragma(classify_level=restricted, topic={db_difference_tool})
wdi_db_difference_gui_plugin.define_shared_variable(:active_instance, _unset, :public)	
$
_pragma(classify_level=restricted, topic={db_difference_tool})
wdi_db_difference_gui_plugin.define_shared_variable(:report_dir, _unset, :public)
$


_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.build_gui(container)
	## Build GUI in container
	>> _self.activate_in(container)
_endmethod
$

# ==============================================================================
#                        GUI Layout
# ==============================================================================
_method wdi_db_difference_gui_plugin.activate_in(p_frame)

    
	_if smallworld_product.release_version = 5
	_then
		write("+++ 33333333333 +++")
		
		_self.activate_dialog_version5(p_frame)
	_else
		write("+++ in else 3 4 +++")
		
		_self.activate_dialog_version3_version4(p_frame)
	_endif 


_endmethod
$

_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.activate_dialog_version5(p_frame)
	## 
	## 
	 write("+++ 444444444 +++")
         
	wdi_db_difference_gui_plugin.active_instance << _self  
	p_frame.default_resize? << _true
	p_frame.title << "Database Difference Tool"

	# ================= MAIN CONTAINER =================
	main_rc << rowcol.new(p_frame, _unset, 1)
	main_rc.resize_x? << _true
	main_rc.resize_y? << _true
	main_rc.outer_spacing << 10
	main_rc.row_resize_values << {0, 0, 40, 0, 60, 0}

	# ================= STATUS =================
	status_rc << rowcol.new(main_rc, 1, 2)
	label_item.new(status_rc, "Status:")
	.items[:st] << label_item.new(status_rc, "Ready...")

	# ================= DATASET =================
	dataset_rc << rowcol.new(main_rc, 1, 1)
	.items[:dataset] << text_choice_item.new(dataset_rc,
						 "DATASETS *",
						 :items, _self.db_list(),
						 :model, _self,
						 :col_alignment, :left,
						 :change_selector, :dataset_changed|()|)

	# ================= TABLES =================
	label_item.new(main_rc, "TABLES *",:col_alignment, :left )

	table_rc << rowcol.new(main_rc, _unset, 1)
	table_rc.resize_x? << _true
	table_rc.resize_y? << _true
	

        _local l_table_tree << .table_tree_item << tree_item.new(table_rc,
								 :model, _self,
								 :aspect, :tables_aspect,
								 :column_headings, {"Select", "Table Name"},
								 :column_heading_ids, {:check, :table_name},
								 :column_widths, {100, 250},
								 :col_alignment, :fill,
								 :row_alignment, :left,
								 :column_alignments, {:centre, :left},
								 :grid_lines?, _true,
								 :height, 150,
								 :mode, :none,
								 :value_click_notifier, :note_changes|()|)

	

	# ================= Alternative INPUT =================
	
	alt_rc << rowcol.new(main_rc, 3, 2)
	#alt_rc.col_alignment << :fill

        label_item.new(alt_rc,"")

	.items[:from_alternative] << text_item.new(alt_rc, " FROM ALTERNATIVE ",:row, 2, :col, 1,:min_width, 150)
	button_item.new_safe(alt_rc, "Select From Alt",
			     _self, :open_version_dialog_from|()|,:col_alignment, :left,:row, 2, :col, 2,:min_width, 50)

	.items[:to_alternative] << text_item.new(alt_rc, " TO ALTERNATIVE       ",:row, 3, :col, 1,:min_width, 150)
	button_item.new_safe(alt_rc, "Select To Alt     ",
			     _self, :open_version_dialog_to|()|,:col_alignment, :left,:row, 3, :col, 2,:min_width, 50)

	# ================= CHECKPOINT =================
	chk_rc << rowcol.new(main_rc, 2, 1)
	chk_rc.col_alignment << :left

	.items[:from_checkpoint] << text_choice_item.new(chk_rc,
							 " FROM CHECKPOINT  ",
							 :items, _self.chk_list(),
							 :model, _self,
							 :min_width, 200  )

	.items[:to_checkpoint] << text_choice_item.new(chk_rc,
						       " TO CHECKPOINT        ",
						       :items, _self.chk_list(),
						       :model, _self,
						       :min_width, 200)

	# ================= MODE =================
	mode_rc << rowcol.new(main_rc, 2, 1)

	label_item.new(mode_rc,
		       "Select below Alternative/Checkpoint Mode to find the data differences between them :")

	radio_rc << rowcol.new(mode_rc, 1, 2)
	.items[:rb_alt] << radio_item.new(radio_rc, " Alternative ",
					  :group, :mode_group,
					  :model, _self,:col_alignment, :left)
	.items[:rb_chk] << radio_item.new(radio_rc, " Checkpoint ",
					  :group, :mode_group,
					  :model, _self,:col_alignment, :centre)


	# ================= ACTION BUTTONS =================
	btn_rc << rowcol.new(main_rc, 1, 2)
	button_item.new_safe(btn_rc, "Find Difference",
			     _self, :find_difference|()|)

	button_item.new_safe(btn_rc, "Clear Selection",
			     _self, :clear_form|()|)

	label_item.new(main_rc,"")

	# ================= RESULTS =================
	result_rc << rowcol.new(main_rc, _unset, 1)
	result_rc.resize_x? << _true
	result_rc.resize_y? << _true

	.items[:tree_item] << tree_item.new(result_rc,
					    :col_alignment, :fill,
					    :row_alignment, :fill,
					    :model, _self,
					    :aspect, :difference_records,
					    :style_holder, _unset,
					    :column_headings, {"SNO", " Table Name","Table Key Field","Table Key Value", "Operation Type","Updated Field name","Before Value","Afetr Value"},
					    :column_heading_ids, {:Sno, :Tablename,:table_key_field,:table_key_value, :Operation_type,:updated_fields,:before_value,:after_value},
					    :column_widths, {150, 150, 150, 150,150,150,150,150},
					    :column_alignments, {:left, :left, :left, :left,:left,:left,:left,:left},
					    :row_headings?, _true,
					    :row_headings_alignment, :right,
					    :cell_selection?, _true,
					    :grid_lines?, _true,
					    :mode, :one,
					    :select_notifier, :|selected()|)

	# ================= FOOTER =================
	footer_rc << rowcol.new(main_rc, 1, 2)

	.items[:generate_report] << button_item.new_safe(footer_rc,
							 "Export Results", _self, :export_results|()|,
							 :enabled?, _false)

	button_item.new_safe(footer_rc,
			     "Clear Results", _self, :clear_results|()|)
	write("+++  5555555555+++")
	
_endmethod
$
_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.activate_dialog_version3_version4(p_frame)
