# ==============================================================================
# Dataset / Table population
# ==============================================================================
_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.db_list()
	##
	## Build and return a rope of available GIS database names for the
	## DATASETS dropdown.  The first entry is a "Select" prompt.
	##
	_local gpm << gis_program_manager
	_local l_rp << rope.new_with("------Select---------")
	l_db << gpm.databases
	
	_for a_db _over l_db.fast_elements()
	_loop
		db_l << a_db.external_name
		l_rp.add(db_l)
	_endloop
	
	>> l_rp
_endmethod
$

# --- Dataset changed ---
_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.dataset_changed(p_value)
        ##
	## Called when the user selects a new dataset from the DATASETS dropdown.
	## Reloads the table tree and resets all comparison fields.
	##
	## Parameters:
	##   p_value - External name string of the newly selected dataset.
	##
	_local l_db
 
	_if p_value = "------Select---------"
	_then
		_return
	_endif
	_local gpm << gis_program_manager
	
	.current_dataset << p_value.lowercase.as_symbol()               
	.db_view  << gpm.databases[.current_dataset]
	

	# --- Build and display tables ---
	_if .db_view _isnt _unset 
	_then
		 
		.table_list << _self.build_table_list()
		_self.changed(:tables_aspect, :renew)
	_endif

	# Clear values
	.items[:from_alternative].value << ""
	.items[:to_alternative].value << ""
	#.items[:from_checkpoint].value << ""
	#.items[:to_checkpoint].value << ""

	# Clear results tree and list
	_if .items[:tree_item] _isnt _unset
	_then
		.items[:tree_item].clear()
	_endif
	.list << rope.new()
	.items[:generate_report].enabled? << _false
	
	.items[:st].value << " Dataset loaded: " + p_value

_endmethod
$
_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.table_tree_note_changes(p_tree, p_id, p_value)
	## 
	## Called by the table tree when a checkbox value changes.
	## When the "All" row is toggled, propagates the new check state to
	## every other row in the table list.
	##
	## Parameters:
	##   p_tree  - The display_tree node whose value changed.
	##   p_id    - The column id that changed (expected :check).
	##   p_value - The new boolean value of the checkbox.
	##
	
	_if p_id _is :check
	_then
		_if p_tree.value[:table_name] = "All"
		_then
			_local all_checked? << p_value
			_for a_dt _over .table_list.fast_elements()
			_loop
				_if a_dt.value[:table_name] _isnt "All"
				_then
					a_dt.value[:check] << all_checked?
				_endif
			_endloop
			_self.changed(:tables_aspect, :refresh)
		_endif
	_endif
	
_endmethod
$
_method wdi_db_difference_gui_plugin.note_changes(p_tree,p_id,p_value)
	## 
	## Called by the table tree when a checkbox value changes.
	## When the "All" row is toggled, propagates the new check state to
	## every other row in the table list.
	##
	## Parameters:
	##   p_tree  - The display_tree node whose value changed.
	##   p_id    - The column id that changed (expected :check).
	##   p_value - The new boolean value of the checkbox.
	##
	 write("+++ note_changes method  +++")
	 
	_if p_id _is :check
	_then
		_if p_tree.value[:table_name] = "All"
		_then
			_local all_checked? << p_value
			_for a_dt _over .table_list.fast_elements()
			_loop
				write("+++ inside loop  +++")
				
				_if a_dt.value[:table_name] _isnt "All"
				_then
					a_dt.value[:check] << all_checked?
				_endif
			_endloop
			_self.changed(:tables_aspect, :refresh)
		_endif
	_endif

	
_endmethod
$
_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.tables_aspect
        ##
	## Aspect accessor for the table-selection tree_item.
	## Returns the current table_list rope.
	##
	>> .table_list	
_endmethod
$

# --- Build table list ---
_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.build_table_list()
        ##
	## Construct and return a rope of display_tree nodes representing the
	## user-visible tables in the current database view.
	## The first node is an "All" toggle row for select-all behaviour.
	##
	_local l_list << rope.new()
	
	_local l_styled_string << styled_string.new(
		                     :toggle, :check,
		                     :tab, :value, :table_name)

	_if .db_view _isnt _unset
	_then
	        # Add ALL row
		_local l_value << property_list.new_with(:table_name, "All",:check, _false)
		
		_local l_display_tree << display_tree.new("All", l_value)
		l_display_tree.styled_string << l_styled_string
		l_list.add(l_display_tree)

		#  One row per user table, sorted alphabetically
		_for a_t _over .db_view.user_table_names.as_sorted_collection().fast_elements()
		_loop
			l_value << property_list.new_with(:table_name, a_t,:check, _false)

			l_display_tree << display_tree.new(a_t, l_value)
			l_display_tree.styled_string << l_styled_string
			l_list.add(l_display_tree)
		_endloop
	
	_endif

	>> l_list
	
_endmethod
$
# ==============================================================================
# Mode handling (Alternative vs Checkpoint)
# ==============================================================================
_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.mode_changed()
	##
	## Called when the user switches between Alternative and Checkpoint mode.
	## Enables the fields relevant to the selected mode and disables the others.
	##

		
	_if .items[:rb_alt].value
	_then
		# Alternative mode
		.items[:from_alternative].enabled? << _true
		.items[:to_alternative].enabled? << _true
		.items[:from_checkpoint].enabled? << _true
		.items[:to_checkpoint].enabled? << _true
		
	_elif .items[:rb_chk].value
	_then
		# Checkpoint mode
		.items[:from_checkpoint].enabled? << _true
		.items[:to_checkpoint].enabled? << _true
		.items[:from_alternative].enabled? << _true
		.items[:to_alternative].enabled? << _true
	_endif
_endmethod
$
# ==============================================================================
# Table selection helpers
# ==============================================================================
_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.get_selected_tables()
        ##
	## Return a rope of collection objects for every table whose checkbox is
	## ticked in the table-selection tree.
	## If the "All" row is checked, returns all user-visible collections.
	##

	
	_local selected_tables << rope.new()
	
	_if .table_list _isnt _unset
	_then
		_for a_dt _over .table_list.fast_elements()
		_loop
			_if a_dt.value[:check] _is _true _andif
			    a_dt.value[:table_name] _isnt "All"
			_then
				# Get the actual collection object, not just the name
				table_name_sym << a_dt.value[:table_name].as_symbol()
				_if .db_view.collections[table_name_sym] _isnt _unset
				_then
					selected_tables.add(.db_view.collections[table_name_sym])
				_endif
			_endif
		_endloop
	_endif
	
	# If ALL was checked, return all table collections
	_if .table_list.size > 0 _andif
	   .table_list.first.value[:check] _is _true
	_then
		selected_tables << rope.new()
		_for a_tbl _over .db_view.user_table_names.fast_elements()
		_loop
			_if .db_view.collections[a_tbl] _isnt _unset
			_then
				selected_tables.add(.db_view.collections[a_tbl])
			_endif
		_endloop
	_endif
	
	>> selected_tables
	
_endmethod
$


_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.difference_records
	## Returns the list of difference records to be displayed
	#	write("difference_records method called")
	>> .list
_endmethod
$

# ==============================================================================
# Results display builder
# ==============================================================================
_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.build_results_display(ht, p_old_view, p_new_view)
	##
	## Convert the raw difference hash table (ht) into a rope of display_tree
	## nodes and refresh the results tree widget.
	##
	## INSERT and REMOVE records appear as top-level rows.
	## UPDATE records appear as top-level rows with child rows for each
	## changed field showing before/after values.
	##
	## Only records belonging to the user-selected tables are included.
	##
	## Parameters:
	##   ht          - Hash table with :insert / :update / :remove sets.
	##   p_old_view  - The "from" database view (used for field comparison).
	##   p_new_view  - The "to"   database view (used for field comparison).
	##
	_local result_list << rope.new()
	_local counter << 0
	_local  selected_tables << _self.get_selected_tables()
	_local l_styled_string << styled_string.new(
					  :value, :Sno,
					  :tab, :value, :Table_name,
					  :tab, :value, :table_key_field,
					  :tab, :value, :table_key_value,
					  :tab, :value, :Operation_type,
					  :tab, :value, :updated_fields,
					  :tab, :value, :before_value,
					  :tab, :value, :after_value)
	
	# --------------------------------------------- INSERT records-----------------------------------------------------

			
	_for a_rec _over ht[:insert].fast_elements()
	_loop
	     	_if smallworld_product.release_version =  3
		_then
			l_tables? <<selected_tables.equality_includes?(a_rec.source_collection)	
		_elif smallworld_product.release_version =  4 _orif smallworld_product.release_version =  5
		_then 
			
			l_tables? <<  selected_tables.includes_by_equality?(a_rec.source_collection)
		_endif 
		_if a_rec.is_rwo? _andif l_tables?
		_then
			counter +<< 1
			_if a_rec.responds_to?(:id)
			_then
			
				l_key_field << "ID"
				l_key_value << a_rec.id.write_string
			_elif a_rec.responds_to?(:name)
			_then
			
				l_key_field << "Name"
				l_key_value << a_rec.name
			_else
				l_key_field << "Unknown"
				l_key_value << a_rec
				
			_endif
			l_value << property_list.new_with(
					   :Sno, counter.write_string,
					   :Table_name, a_rec.source_collection.external_name,
					   :table_key_field,l_key_field ,
					   :table_key_value,l_key_value, 
					   :Operation_type, "INSERT",
					   :updated_fields,"",
					   :before_value,"",
					   :after_value,"")
			
			l_dp << display_tree.new(counter, l_value)
			l_dp.styled_string << l_styled_string
			
		        result_list.add(l_dp)
			
		_endif
	_endloop
	
	#-------------------------------------------- Process UPDATE records------------------------------------------
	_for a_rec _over ht[:update].fast_elements()
	_loop
		_if smallworld_product.release_version =  3
		_then
			l_tables? <<selected_tables.equality_includes?(a_rec.source_collection)	
		_elif smallworld_product.release_version =  4 _orif smallworld_product.release_version =  5
		_then 
			
			l_tables? <<  selected_tables.includes_by_equality?(a_rec.source_collection)
		_endif
		_if a_rec.is_rwo? _andif l_tables?
		_then
		     	counter +<< 1
				_if a_rec.responds_to?(:id)
			_then
			
				l_key_field << "ID"
				l_key_value << a_rec.id.write_string
			_elif a_rec.responds_to?(:name)
			_then
			
				l_key_field << "Name"
				l_key_value << a_rec.name
			_else
				l_key_field << "Unknown"
				l_key_value << a_rec
			
			_endif
		
		
			l_value << property_list.new_with(
					   :Sno, counter.write_string,
					   :Table_name, a_rec.source_collection.external_name,
					   :table_key_field, l_key_field,
					   :table_key_value, l_key_value,
					   :Operation_type, "UPDATE",
					   :updated_fields,"",
				           :before_value,"",
					   :after_value,"")
			l_dp << display_tree.new(counter, l_value)
			l_dp.styled_string << l_styled_string

			# Add child rows for each changed field
			 child_counter << 0
			_for a_field _over a_rec.visible_fields.fast_elements()
			_loop
				(diff?, old_val, new_val)  << _self.compare_record(p_old_view, p_new_view, a_rec, a_field.name)
				
			        _if diff?
				_then
					
					_if a_rec.field(a_field.name).responds_to?(:join_type) _andif


					    a_rec.field(a_field.name).join_type = :db_set_join 
					_then
					  
					       _continue  
					       	
					_endif
					child_counter +<< 1  # first diff becomes .1, second .2, etc.
					# Create a new property list for each changed field
					l_child_val << property_list.new_with(
							       :Sno, counter.write_string + "." + child_counter.write_string,
							       :Table_name, a_rec.source_collection.external_name,
							       :table_key_field, l_key_field,
							       :table_key_value, l_key_value,
							       :Operation_type, "UPDATE",
							       :updated_fields,a_field.name.write_string,
							       :before_value, old_val.write_string,
                                                               :after_value, new_val.write_string)
					
					l_child_dp << display_tree.new(counter.write_string + "." + child_counter.write_string, l_child_val)
					l_child_dp.styled_string << l_styled_string
					l_dp.add_child(l_child_dp)
						
	                        
				_endif
				
			_endloop
			
			result_list.add(l_dp)	
		_endif
		
	_endloop
	
	#---------------------------------------------------------- Process REMOVE records-----------------------------------------------------
	_for a_rec _over ht[:remove].fast_elements()
	_loop
		_if smallworld_product.release_version =  3
		_then
			l_tables? <<selected_tables.equality_includes?(a_rec.source_collection)	
		_elif smallworld_product.release_version =  4 _orif smallworld_product.release_version =  5
		_then 
			
			l_tables? <<  selected_tables.includes_by_equality?(a_rec.source_collection)
		_endif
		_if a_rec.is_rwo? _andif l_tables?
		_then
		  	counter +<< 1
		        		_if a_rec.responds_to?(:id)
			_then
		
				l_key_field << "ID"
				l_key_value << a_rec.id.write_string
			_elif a_rec.responds_to?(:name)
			_then
			
				l_key_field << "Name"
				l_key_value << a_rec.name
			_else
				l_key_field << "Unknown"
				l_key_value << a_rec
				
			_endif
		
			l_value << property_list.new_with(
					   :Sno, counter.write_string,
					   :Table_name, a_rec.source_collection.external_name,
					   :table_key_field,l_key_field,
					   :table_key_value, l_key_value,
					   :Operation_type, "REMOVE",
					   :updated_fields,"",
					   :before_value,"",
					   :after_value,"")
			
			l_dp << display_tree.new(counter, l_value)
			l_dp.styled_string << l_styled_string
			result_list.add(l_dp)	
		_endif
		
	_endloop
        # -------------------- Finalize ---------------------------------------------
	# Update the list and refresh display
	.list << result_list
	_self.changed(:difference_records, :renew)
	
_endmethod
$

# ==============================================================================
# Clear / Reset methods
# ==============================================================================
_pragma(classify_level=restricted, topic={db_difference_tool})
_method wdi_db_difference_gui_plugin.clear_form()
	## Clear all form fields
	
	_try
		.items[:dataset].value << "------Select---------"
		
		# Uncheck all tables
		_if .table_list _isnt _unset
		_then
			_for a_dt _over .table_list.fast_elements()
			_loop
				a_dt.value[:check] << _false
			_endloop
			_self.changed(:tables_aspect, :refresh)
		_endif
		
		.items[:generate_report].enabled? << _false

		# Reset alternatives and checkpoints
		.items[:from_alternative].value << ""
		.items[:to_alternative].value << ""
		.items[:from_checkpoint].value <<"---Select---"
		.items[:to_checkpoint].value << "---Select---"

		# Reset radio buttons
		.items[:rb_alt].value << _false
		.items[:rb_chk].value << _false


		.items[:st].value << " Ready..."
	_when error
		!error_output!.write("Clear form error: ", condition.report_contents_string, newline_char)
	_endtry
_endmethod
$


